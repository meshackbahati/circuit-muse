{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "CircuitMuse",
  "version": "1.0.1",
  "identifier": "dev.circuit-muse",
  "build": {
    "frontendDist": "../app/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "CircuitMuse",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/arduino-cli"
    ],
    "resources": [
      "binaries/circuit-muse-engine"
    ],
    "targets": "all"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
